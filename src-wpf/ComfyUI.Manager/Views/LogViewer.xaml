<UserControl x:Class="ComfyUI.Manager.Views.LogViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <Button DockPanel.Dock="Top" Content="清空"
                Command="{Binding ClearCommand}"
                Style="{StaticResource MaterialButton}"
                HorizontalAlignment="Right" Margin="8" />
        <ListBox ItemsSource="{Binding Lines}"
                 FontFamily="Consolas" FontSize="12">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Text}" TextWrapping="NoWrap" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>