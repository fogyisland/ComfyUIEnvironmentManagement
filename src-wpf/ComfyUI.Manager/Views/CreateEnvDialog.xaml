<Window x:Class="ComfyUI.Manager.Views.CreateEnvDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ComfyUI.Manager.Views"
        Title="新建环境" Height="450" Width="560"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="16">
        <TextBlock Text="名称" />
        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                 IsEnabled="{Binding IsBusy, Converter={x:Static views:NotBoolConverter.Instance}}"
                 Margin="0,2,0,8" />

        <TextBlock Text="布局" />
        <ComboBox SelectedItem="{Binding Layout}"
                  ItemsSource="{Binding LayoutOptions}"
                  IsEnabled="{Binding IsBusy, Converter={x:Static views:NotBoolConverter.Instance}}"
                  Margin="0,2,0,8" />

        <TextBlock Text="Python 解释器 (python.exe)" />
        <DockPanel Margin="0,2,0,8">
            <Button DockPanel.Dock="Right" Content="浏览..."
                    Click="BrowsePython"
                    IsEnabled="{Binding IsBusy, Converter={x:Static views:NotBoolConverter.Instance}}"
                    Margin="4,0,0,0" />
            <TextBox Text="{Binding PythonExe, UpdateSourceTrigger=PropertyChanged}" />
        </DockPanel>

        <TextBlock Text="ComfyUI 源(shared 必填,independent 作为拷贝来源)" />
        <DockPanel Margin="0,2,0,8">
            <Button DockPanel.Dock="Right" Content="浏览..."
                    Click="BrowseComfyui"
                    IsEnabled="{Binding IsBusy, Converter={x:Static views:NotBoolConverter.Instance}}"
                    Margin="4,0,0,0" />
            <TextBox Text="{Binding ComfyuiSource, UpdateSourceTrigger=PropertyChanged}" />
        </DockPanel>

        <TextBlock Text="端口(留空自动分配,从 8188 起)" />
        <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,2,0,8" />

        <TextBlock Text="{Binding ErrorMessage}" Foreground="Red"
                   TextWrapping="Wrap" Margin="0,4,0,0"
                   Visibility="{Binding ErrorMessage, Converter={x:Static views:NullToVisibilityConverter.Instance}}" />

        <StackPanel Orientation="Horizontal" Margin="0,16,0,0"
                    HorizontalAlignment="Right">
            <Button Content="创建" Command="{Binding CreateCommand}"
                    Style="{StaticResource MaterialButton}"
                    Width="80" />
            <Button Content="取消" Command="{Binding CancelCommand}"
                    Style="{StaticResource MaterialButton}"
                    Margin="8,0,0,0" Width="80" />
        </StackPanel>
    </StackPanel>
</Window>
